# TaskFlow 后端环境变量
# 复制此文件为 .env 并根据需要修改
# 注意：config.py 中所有变量都有 TASKFLOW_ 前缀

# JWT 密钥（生产环境请更换为随机字符串）
TASKFLOW_SECRET_KEY=更换为随机生成的强密钥

# 数据库（SQL Server）
TASKFLOW_DB_HOST=localhost
TASKFLOW_DB_PORT=
TASKFLOW_DB_USER=
TASKFLOW_DB_PASSWORD=
TASKFLOW_DB_NAME=taskflow
TASKFLOW_DB_DRIVER=ODBC Driver 17 for SQL Server

# SMTP 邮件（QQ邮箱，可选，不填则邮件功能不可用）
TASKFLOW_SMTP_HOST=smtp.qq.com
TASKFLOW_SMTP_PORT=587
TASKFLOW_SMTP_USER=
TASKFLOW_SMTP_PASSWORD=
TASKFLOW_SMTP_FROM_NAME=TaskFlow

# CORS 来源（可选，逗号分隔）
TASKFLOW_CORS_ORIGINS=http://localhost:5173
